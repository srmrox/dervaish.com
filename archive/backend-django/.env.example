# Copy to .env for local dev, or set these in Coolify's env panel for production.

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.dervaish.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.dervaish.com
DJANGO_CORS_ALLOWED_ORIGINS=https://dervaish.com,https://www.dervaish.com
DJANGO_TIME_ZONE=Asia/Karachi

# --- Database (leave empty to use local SQLite) ---
DATABASE_URL=postgres://dervaish:dervaish@localhost:5432/dervaish

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (Cloudflare R2 / S3 / MinIO) ---
# Local dev defaults to off (FileSystem storage). In production set USE_S3=true.
# Cloudflare R2 (recommended, master plan §4A): zero egress + CDN via custom domain.
#   S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_CUSTOM_DOMAIN=media.dervaish.com   (the bucket's attached custom domain → CDN URLs)
USE_S3=false
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=dervaish
S3_SECRET_ACCESS_KEY=dervaish-local
S3_BUCKET=dervaish
S3_REGION=auto
S3_CUSTOM_DOMAIN=
S3_QUERYSTRING_AUTH=false

# --- Compose-only secrets (used by docker-compose.coolify.yml) ---
POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=dervaish
MINIO_ROOT_PASSWORD=change-me-too

# --- Gunicorn ---
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
