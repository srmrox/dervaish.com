# Dervaish Node API — environment (loaded via `node --env-file=.env`, no dotenv)
# Port the frontend Vite proxy points at (keep 8000 to avoid touching vite.config.ts).
PORT=8000
HOST=0.0.0.0

# Media root: repo-root mediafiles/, resolved relative to this package dir (apps/api).
MEDIA_ROOT=../../mediafiles

# SQLite file, opened by node:sqlite.
DB_PATH=./dervaish.db
